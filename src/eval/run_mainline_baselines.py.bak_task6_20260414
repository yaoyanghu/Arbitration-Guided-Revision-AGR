def merge_variant(base: dict[str, Any], overrides: dict[str, Any]) -> dict[str, Any]:
    config = deepcopy(base)
    config["mainline"].update(overrides)
    return config


def ensure_index(config: dict[str, Any]) -> None:
    mainline = config["mainline"]
    index_dir = Path(mainline["bm25_index_dir"])
    corpus_path = Path(mainline["corpus_path"])
    json_index = index_dir / "bm25_index.json"
    sqlite_index = index_dir / "bm25_fts.db"
    if not json_index.exists() and not sqlite_index.exists():
        build_and_save_index(corpus_path, index_dir, backend="auto")
        return

    if json_index.exists():
        current_count = sum(1 for _ in read_jsonl(corpus_path))
        payload = read_json(json_index)
        indexed_count = len(payload.get("corpus", []))
        if indexed_count != current_count:
            build_and_save_index(corpus_path, index_dir, backend="json")


def main() -> None:
    parser = argparse.ArgumentParser(description="Run baseline matrix for the New_ChronoRAG mainline.")
    parser.add_argument("--config", required=True)
    parser.add_argument("--run-group", required=True)
    parser.add_argument("--variants", nargs="*", default=list(variant_overrides().keys()))
    args = parser.parse_args()

    base_config = load_config(args.config)
    ensure_index(base_config)
    run_group_dir = ensure_dir(Path(base_config["paths"]["runs_dir"]) / args.run_group)
    summary_rows = []

    for variant in args.variants:
        overrides = variant_overrides()[variant]
        variant_config = merge_variant(base_config, overrides)
        exp_name = f"{args.run_group}__{variant}"
        result = run_pipeline(variant_config, exp_name)
        summary_rows.append(
            {
                "variant": variant,
                "run_dir": result["run_dir"],
                "metrics": result["metrics"],
            }
        )

    write_json(run_group_dir / "summary.json", {"variants": summary_rows, "timestamp": datetime.now().isoformat()})
    write_jsonl(
        run_group_dir / "summary.jsonl",
        [
            {
                "variant": row["variant"],
                "run_dir": row["run_dir"],
                "exact_match": row["metrics"]["answer_level"]["exact_match"],
                "token_f1": row["metrics"]["answer_level"]["token_f1"],
                "citation_title_recall": row["metrics"]["answer_level"]["citation_title_recall"],
                "status": row["metrics"]["status"],
            }
            for row in summary_rows
        ],
    )
    lines = [
        "# Mainline Baseline Summary",
        "",
        "| variant | exact_match | token_f1 | citation_title_recall | run_dir |",
        "| --- | ---: | ---: | ---: | --- |",
    ]
    for row in summary_rows:
        metrics = row["metrics"]["answer_level"]
        lines.append(
            f"| {row['variant']} | {metrics['exact_match']:.3f} | {metrics['token_f1']:.3f} | {metrics['citation_title_recall']} | {row['run_dir']} |"
        )
    (run_group_dir / "summary.md").write_text("\n".join(lines), encoding="utf-8")
    print(json.dumps({"run_group": args.run_group, "variants": [row["variant"] for row in summary_rows]}, ensure_ascii=False, indent=2))


if __name__ == "__main__":
    main()
